{
  "name": "fms-app",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "bun .output/server/index.mjs",
    "supabase:up": "docker compose -f supabase/docker-compose.yml --env-file .env up -d",
    "supabase:down": "docker compose -f supabase/docker-compose.yml --env-file .env down",
    "supabase:prod:up": "docker compose -f supabase/docker-compose.yml -f supabase/docker-compose.prod.yml --env-file .env up -d",
    "supabase:prod:down": "docker compose -f supabase/docker-compose.yml -f supabase/docker-compose.prod.yml --env-file .env down",
    "supabase:migrate": "docker exec -i supabase-db psql -U postgres -d postgres",
    "supabase:shell": "docker exec -it supabase-db psql -U postgres -d postgres",
    "gen:types": "node_modules/.bin/supabase gen types typescript --db-url postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/postgres > src/lib/database.types.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "deploy:cf": "wrangler deploy --config deploy/cloudflare/wrangler.toml",
    "deploy:docker": "docker build -t fms-app:latest . && docker push fms-app:latest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@base-ui/react": "^1.4.1",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.4",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "@tanstack/react-form": "^0.41.3",
    "@tanstack/react-query": "^5.62.7",
    "@tanstack/react-router": "^1.95.1",
    "@tanstack/react-router-with-query": "^1.95.1",
    "@tanstack/react-start": "^1.167.49",
    "@tanstack/react-table": "^8.20.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.11.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4",
    "recharts": "3.8.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.5.5",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.35.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/router-plugin": "^1.167.27",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "supabase": "^2.98.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^3.99.0"
  },
  "engines": {
    "bun": ">=1.2"
  }
}