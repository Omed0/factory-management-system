# =============================================================================
# Factory Management System — environment
# Copy to `.env` (root) and `.env` (supabase/) and fill in.
# DO NOT commit a real .env to git.
# =============================================================================

# ─── Supabase self-host (matches keys expected by official docker stack) ─────
POSTGRES_PASSWORD=replace-me-strong-postgres-password
POSTGRES_DB=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432

# JWT — generate real HS256 tokens with the bun script in docs/development.md
JWT_SECRET=replace-me-min-32-chars-jwt-secret
JWT_EXPIRY=3600
ANON_KEY=replace-me-anon-jwt-signed-with-JWT_SECRET
SERVICE_ROLE_KEY=replace-me-service-role-jwt-signed-with-JWT_SECRET
SECRET_KEY_BASE=replace-me-64-chars-random
VAULT_ENC_KEY=0123456789abcdef0123456789abcdef

DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=replace-me

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
PGRST_DB_SCHEMAS=public,storage
PG_META_CRYPTO_KEY=abcdef0123456789abcdef0123456789

SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=http://localhost:3000
API_EXTERNAL_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000

DISABLE_SIGNUP=true
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false

SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Factory
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify

STUDIO_DEFAULT_ORGANIZATION=Factory
STUDIO_DEFAULT_PROJECT=Factory
LOGFLARE_PUBLIC_ACCESS_TOKEN=replace-me
LOGFLARE_PRIVATE_ACCESS_TOKEN=replace-me

POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_TENANT_ID=fms
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_DB_POOL_SIZE=5

GLOBAL_S3_BUCKET=stub
STORAGE_TENANT_ID=fms
REGION=local
S3_PROTOCOL_ACCESS_KEY_ID=
S3_PROTOCOL_ACCESS_KEY_SECRET=
IMGPROXY_AUTO_WEBP=true
DOCKER_SOCKET_LOCATION=/var/run/docker.sock
FUNCTIONS_VERIFY_JWT=true

# ─── App ─────────────────────────────────────────────────────────────────────
APP_PORT=3000
NODE_ENV=production

# Supabase URL the app uses (server-side; ANON_KEY exposed to browser via PUBLIC_* / VITE_*)
# IMPORTANT: ${VAR} expansion is NOT supported in all runtimes (Bun, Docker).
# Paste the literal values from ANON_KEY / SERVICE_ROLE_KEY below — do not use ${} references.
SUPABASE_URL=http://localhost:8000
PUBLIC_SUPABASE_URL=http://localhost:8000
PUBLIC_SUPABASE_ANON_KEY=replace-me-same-literal-value-as-ANON_KEY
VITE_SUPABASE_URL=http://localhost:8000
VITE_SUPABASE_ANON_KEY=replace-me-same-literal-value-as-ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=replace-me-same-literal-value-as-SERVICE_ROLE_KEY

# ─── Backups ─────────────────────────────────────────────────────────────────
# Provider is also stored in site_settings (DB-driven). These envs are only
# the credentials the provider needs.
#
# Cloudflare R2:
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fms-backups
R2_ENDPOINT=https://example.r2.cloudflarestorage.com

# Local/VPS backup target paths (used when provider = 'local' or 'vps')
LOCAL_BACKUP_DIR=/var/backups/fms
VPS_BACKUP_DIR=/var/backups/fms

# ─── VPS deploy (Caddy / docker-compose.prod.yml) ────────────────────────────
# Domain names that Caddy gets certs for:
APP_DOMAIN=app.your-domain.com
API_DOMAIN=api.your-domain.com
STUDIO_DOMAIN=studio.your-domain.com

# Caddy basic-auth for Supabase Studio.
# Generate hash: docker run --rm caddy:2-alpine caddy hash-password --plaintext '<pw>'
STUDIO_USER=admin
STUDIO_PASS_HASH=replace-me-caddy-hash

# GitHub container registry owner (used by docker-compose.prod.yml to pull the app image).
# Set to your GitHub username / org, e.g. myorg or myusername.
GH_OWNER=yourname
APP_TAG=latest

# ─── Cloudflare deploy (Workers) ─────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
